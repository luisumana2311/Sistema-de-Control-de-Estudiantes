{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "python": "3.12"
  },
  "steps": {
    "install": {
      "commands": ["...", "python -m pip install --no-cache-dir -r requirements.txt"]
    }
  },
  "deploy": {
    "startCommand": "uvicorn student_control_system.api:app --host 0.0.0.0 --port $PORT"
  }
}
